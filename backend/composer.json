{
  "name": "connecto/backend",
  "description": "Connecto Laravel REST API for a two-sided mock interview marketplace.",
  "type": "project",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0",
    "laravel/socialite": "^5.16",
    "stripe/stripe-php": "^16.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
